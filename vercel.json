{
  "version": 2,
  "rewrites": [
    { "source": "/api/auth/(.*)", "destination": "/api/auth.js" },
    { "source": "/api/complaints/(.*)", "destination": "/api/complaints.js" },
    { "source": "/api/admin/(.*)", "destination": "/api/admin.js" },
    { "source": "/api/officer/(.*)", "destination": "/api/officer.js" },
    { "source": "/api/notifications/(.*)", "destination": "/api/notifications.js" },
    { "source": "/api/users/(.*)", "destination": "/api/users.js" },
    { "source": "/api/ai/(.*)", "destination": "/api/ai.js" },
    { "source": "/api/feedback/(.*)", "destination": "/api/feedback.js" },
    { "source": "/api/dashboard-stats", "destination": "/api/dashboard-stats.js" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}