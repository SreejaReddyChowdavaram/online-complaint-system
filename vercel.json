{
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/auth/(.*)", "dest": "/api/auth.js" },
    { "src": "/api/complaints/(.*)", "dest": "/api/complaints.js" },
    { "src": "/api/admin/(.*)", "dest": "/api/admin.js" },
    { "src": "/api/officer/(.*)", "dest": "/api/officer.js" },
    { "src": "/api/notifications/(.*)", "dest": "/api/notifications.js" },
    { "src": "/api/users/(.*)", "dest": "/api/users.js" },
    { "src": "/api/ai/(.*)", "dest": "/api/ai.js" },
    { "src": "/api/feedback/(.*)", "dest": "/api/feedback.js" },
    { "src": "/api/dashboard-stats", "dest": "/api/dashboard-stats.js" },
    { "src": "/api/(.*)", "dest": "/api/$1.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}