    { "source": "/api/admin/dashboard", "destination": "/api/admin/dashboard.js" },
    { "source": "/api/admin/users", "destination": "/api/admin/users.js" },
    { "source": "/api/admin/complaints", "destination": "/api/admin/complaints.js" },

    { "source": "/api/notifications/mark-read/:id", "destination": "/api/notifications/mark-read.js?id=:id" },
    { "source": "/api/notifications", "destination": "/api/notifications/index.js" },

    { "source": "/api/users/me", "destination": "/api/users/me.js" },
    { "source": "/api/users/profile", "destination": "/api/users/profile.js" },
    { "source": "/api/users/change-password", "destination": "/api/users/change-password.js" },

    { "source": "/api/officer/complaints", "destination": "/api/officer/complaints.js" },
    { "source": "/api/officer/update-complaint/:id", "destination": "/api/officer/update-complaint.js?id=:id" },

