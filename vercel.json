    { "source": "/api/feedback/my-feedback", "destination": "/api/feedback/my-feedback.js" },
    { "source": "/api/feedback/all", "destination": "/api/feedback/all.js" },
    { "source": "/api/feedback/check/:id", "destination": "/api/feedback/check/[id].js" },
    { "source": "/api/feedback", "destination": "/api/feedback/index.js" },

    { "source": "/api/dashboard-stats", "destination": "/api/dashboard-stats.js" }
  ]
}